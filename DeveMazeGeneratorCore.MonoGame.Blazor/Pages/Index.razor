@page "/"
@inject IJSRuntime JsRuntime
@using nkast.Wasm.Canvas

<PageTitle>DeveMazeGeneratorCore</PageTitle>

<div id="canvasHolder" style="margin:0%;
    position: fixed;
    top: 0px;
    right: 0px;
    bottom: 0px;
    left: 0px;
    width:100vw;
    height:100vh;
">
    <canvas id="theCanvas" 
        @ontouchstart="@OnTouchStart"
        @ontouchmove="@OnTouchMove"
        @ontouchend="@OnTouchEnd"
    ></canvas>
    
    <!-- Camera Control UI -->
    <div id="cameraControls" style="position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%); display: @(ShowCameraControls ? "flex" : "none"); flex-direction: column; align-items: center; gap: 10px; user-select: none; -webkit-user-select: none;">
        <!-- Movement Controls -->
        <div style="display: flex; flex-direction: column; align-items: center; gap: 5px;">
            <button @ontouchstart="() => MoveButtonPressed('Forward')" @ontouchend="() => MoveButtonReleased('Forward')" 
                    style="width: 70px; height: 70px; border-radius: 35px; background-color: rgba(0,0,0,0.6); color: white; border: 2px solid rgba(255,255,255,0.5); font-size: 30px; display: flex; justify-content: center; align-items: center; box-shadow: 0 4px 8px rgba(0,0,0,0.3);">
                ▲
            </button>
            <div style="display: flex; gap: 5px;">
                <button @ontouchstart="() => MoveButtonPressed('Left')" @ontouchend="() => MoveButtonReleased('Left')" 
                        style="width: 70px; height: 70px; border-radius: 35px; background-color: rgba(0,0,0,0.6); color: white; border: 2px solid rgba(255,255,255,0.5); font-size: 30px; display: flex; justify-content: center; align-items: center; box-shadow: 0 4px 8px rgba(0,0,0,0.3);">
                    ◄
                </button>
                <button @ontouchstart="() => MoveButtonPressed('Down')" @ontouchend="() => MoveButtonReleased('Down')" 
                        style="width: 70px; height: 70px; border-radius: 35px; background-color: rgba(0,0,0,0.6); color: white; border: 2px solid rgba(255,255,255,0.5); font-size: 30px; display: flex; justify-content: center; align-items: center; box-shadow: 0 4px 8px rgba(0,0,0,0.3);">
                    ▼
                </button>
                <button @ontouchstart="() => MoveButtonPressed('Right')" @ontouchend="() => MoveButtonReleased('Right')" 
                        style="width: 70px; height: 70px; border-radius: 35px; background-color: rgba(0,0,0,0.6); color: white; border: 2px solid rgba(255,255,255,0.5); font-size: 30px; display: flex; justify-content: center; align-items: center; box-shadow: 0 4px 8px rgba(0,0,0,0.3);">
                    ►
                </button>
            </div>
        </div>
    </div>

    <!-- Look/Rotation Control Area -->
    <div id="lookControl" style="position: absolute; bottom: 20px; right: 20px; width: 150px; height: 150px; border-radius: 75px; background-color: rgba(0,0,0,0.5); display: @(ShowCameraControls ? "flex" : "none"); justify-content: center; align-items: center; box-shadow: 0 4px 8px rgba(0,0,0,0.3); border: 2px solid rgba(255,255,255,0.5);"
         @ontouchstart="OnLookControlTouchStart" @ontouchmove="OnLookControlTouchMove" @ontouchend="OnLookControlTouchEnd">
        <div style="color: white; font-size: 20px; text-align: center; user-select: none; -webkit-user-select: none;">
            Look
        </div>
    </div>

    <!-- Top Control Bar -->
    <div style="position: absolute; top: 20px; right: 20px; display: flex; gap: 10px;">
        <!-- Camera Mode Toggle -->
        <button @onclick="ToggleCameraMode" style="padding: 10px; background-color: rgba(0,0,0,0.6); color: white; border: none; border-radius: 5px; box-shadow: 0 4px 8px rgba(0,0,0,0.3);">
            @(IsFpsMode ? "FPS Mode" : "Edit Mode")
        </button>

        <!-- Controls Toggle -->
        <button @onclick="ToggleCameraControls" style="padding: 10px; background-color: rgba(0,0,0,0.6); color: white; border: none; border-radius: 5px; box-shadow: 0 4px 8px rgba(0,0,0,0.3);">
            @(ShowCameraControls ? "Hide Controls" : "Show Controls")
        </button>
    </div>

    <!-- Up/Down Movement Controls -->
    <div style="position: absolute; bottom: 20px; left: 20px; display: @(ShowCameraControls ? "flex" : "none"); flex-direction: column; gap: 10px;">
        <button @ontouchstart="() => MoveButtonPressed('Up')" @ontouchend="() => MoveButtonReleased('Up')" 
                style="width: 70px; height: 70px; border-radius: 35px; background-color: rgba(0,0,0,0.6); color: white; border: 2px solid rgba(255,255,255,0.5); font-size: 24px; display: flex; justify-content: center; align-items: center; box-shadow: 0 4px 8px rgba(0,0,0,0.3);">
            Q
        </button>
        <button @ontouchstart="() => MoveButtonPressed('DownVert')" @ontouchend="() => MoveButtonReleased('DownVert')" 
                style="width: 70px; height: 70px; border-radius: 35px; background-color: rgba(0,0,0,0.6); color: white; border: 2px solid rgba(255,255,255,0.5); font-size: 24px; display: flex; justify-content: center; align-items: center; box-shadow: 0 4px 8px rgba(0,0,0,0.3);">
            E
        </button>
    </div>
</div>
<img id="image1" src="icon-192.png" width="100" height="100" style="visibility:collapse;"/>
